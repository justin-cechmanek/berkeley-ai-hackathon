# Example values for the Radish Bank Iris workshop notebooks.
# refer to "Setting up the environment" section in the README.md file for more details.
OPENAI_API_KEY="sk-proj-EXAMPLE-1234567890"

REDIS_HOST="REDACTED-REDIS-HOST"
REDIS_PORT="19471"
REDIS_PASSWORD="<password>"
REDIS_USER="default"

AGENT_MEMORY_ENDPOINT="https://gcp-us-east4.memory.redis.io"
AGENT_MEMORY_STORE_ID="<store-id>"
AGENT_MEMORY_API_KEY="mem1_B7_AGENT_MEMORY_API_KEY"

LANGCACHE_URL="https://aws-us-east-1.langcache.redis.io"
LANGCACHE_CACHE_ID="<cache-id>"
LANGCACHE_API_KEY="lc1_LANGCACHE_API_KEY"

# Optional defaults
OPENAI_CHAT_MODEL="gpt-4o-mini"


